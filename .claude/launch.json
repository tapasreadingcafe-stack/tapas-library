{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "staff-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "tapas-store",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "tapas-store", "start"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "tapas-website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "tapas-website", "run", "dev"],
      "port": 3002,
      "autoPort": true
    }
  ]
}
